DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=prime
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Set to 1 to auto-create tables on startup from schema.sql
PRIME_AUTO_MIGRATE=1

# Set to 1 to seed sample resources/gallery when empty
PRIME_SEED_DEFAULTS=1

# Admin authentication (session-based)
ADMIN_USERNAME=admin
# Set either ADMIN_PASSWORD (plain) or ADMIN_PASSWORD_HASH (recommended)
ADMIN_PASSWORD=change-me
# Example hash generated with php -r "echo password_hash('change-me', PASSWORD_DEFAULT), PHP_EOL;"
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_NAME=PRIMEADMINSESSID
# Set to 1 when serving API over HTTPS
ADMIN_SESSION_SECURE=0

# SMTP email delivery (set SMTP_ENABLED=1 to send registration confirmation emails)
SMTP_ENABLED=0
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_AUTH=1
SMTP_SECURE=tls
SMTP_TIMEOUT=15
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME="PRIME Conference Team"
SMTP_REPLY_TO=

# Public frontend URLs used in the confirmation email
FRONTEND_URL=http://127.0.0.1:3000
# Optional direct Training section URL (recommended, e.g. http://127.0.0.1:3000#training)
TRAINING_URL=
# Backward-compatible fallback (older "resources" email CTA config)
RESOURCES_URL=

# Stripe Checkout (server-side session creation from Give Online modal)
STRIPE_ENABLED=0
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=usd
# Optional explicit return URLs; defaults to FRONTEND_URL#giving
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_STATEMENT_DESCRIPTOR="PRIME Giving"
